@page "/counter"

<PageTitle>Counter</PageTitle>

<MudText Typo="Typo.h3" GutterBottom="true">Counter</MudText>

<MudGrid>
    <MudItem xs="12" md="6">
        <MudCard>
            <MudCardContent>
                <MudText Typo="Typo.h5" Class="mb-3">Interactive Counter</MudText>
                
                <MudStack Spacing="3">
                    <MudAlert Severity="Severity.Info" Icon="Icons.Material.Filled.Info">
                        Current count: <strong>@currentCount</strong>
                    </MudAlert>
                    
                    <MudButtonGroup Variant="Variant.Filled">
                        <MudButton Color="Color.Primary" 
                                   StartIcon="Icons.Material.Filled.Add" 
                                   OnClick="IncrementCount">
                            Increment
                        </MudButton>
                        <MudButton Color="Color.Secondary" 
                                   StartIcon="Icons.Material.Filled.Remove" 
                                   OnClick="DecrementCount"
                                   Disabled="@(currentCount <= 0)">
                            Decrement
                        </MudButton>
                        <MudButton Color="Color.Warning" 
                                   StartIcon="Icons.Material.Filled.Refresh" 
                                   OnClick="ResetCount">
                            Reset
                        </MudButton>
                    </MudButtonGroup>
                    
                    <MudSlider @bind-Value="currentCount" 
                              Min="0" 
                              Max="100" 
                              Color="Color.Primary" 
                              Variant="Variant.Filled">
                        Use slider to adjust: @currentCount
                    </MudSlider>
                </MudStack>
            </MudCardContent>
        </MudCard>
    </MudItem>
    
    <MudItem xs="12" md="6">
        <MudCard>
            <MudCardContent>
                <MudText Typo="Typo.h5" Class="mb-3">Progress Indicator</MudText>
                
                <MudStack Spacing="3">
                    <MudProgressLinear Value="@progressValue" 
                                       Color="Color.Primary" 
                                       Size="Size.Large" 
                                       Striped="true">
                        <MudText Typo="Typo.body1">@($"{progressValue:F1}%")</MudText>
                    </MudProgressLinear>
                    
                    <MudProgressCircular Value="@progressValue" 
                                         Color="Color.Success" 
                                         Size="Size.Large">
                        @($"{progressValue:F0}%")
                    </MudProgressCircular>
                    
                    @if (currentCount >= 50)
                    {
                        <MudAlert Severity="Severity.Success" Icon="Icons.Material.Filled.CheckCircle">
                            Great job! You've reached 50 or more!
                        </MudAlert>
                    }
                </MudStack>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private int currentCount = 0;
    
    private double progressValue => Math.Min((double)currentCount, 100);

    private void IncrementCount()
    {
        currentCount++;
    }
    
    private void DecrementCount()
    {
        if (currentCount > 0)
            currentCount--;
    }
    
    private void ResetCount()
    {
        currentCount = 0;
    }
}
