@inherits LayoutComponentBase

<MudThemeProvider Theme="_theme" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Surface" Dense="false">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="DrawerToggle"
                       title="Toggle navigation" />
        <MudText Typo="Typo.h6" Class="ml-2">AzDoBoards</MudText>
        <MudSpacer />
        <LoginDisplay />
        <MudIconButton Icon="@Icons.Material.Filled.OpenInNew"
                       Color="Color.Inherit"
                       Href="https://learn.microsoft.com/aspnet/core/"
                       Target="_blank"
                       title="About ASP.NET Core" />
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen"
               ClipMode="DrawerClipMode.Always"
               Elevation="2"
               Variant="DrawerVariant.Responsive"
               Class="app-sidebar">
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.False" Class="pa-6 mt-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#1b6ec2",
            PrimaryDarken = "#1861ac",
            AppbarBackground = "#f7f7f7",
            AppbarText = "#333333",
        }
    };

    private void DrawerToggle() => _drawerOpen = !_drawerOpen;
}
